---
import { business } from '../../data/business';

interface Offer {
  name: string;
  price: string; // z. B. "8.10"
}

interface Props {
  /** Service-Name (mit Ort), z. B. "Malerarbeiten Hamburg" */
  name: string;
  description: string;
  /** Pfad ohne Domain, z. B. "/malerarbeiten-hamburg.html" */
  path: string;
  /** Breadcrumb-Anzeigename */
  breadcrumbName: string;
  offers?: Offer[];
}

const { name, description, path, breadcrumbName, offers } = Astro.props;
const base = business.url.replace(/\/$/, '');
const pageUrl = `${base}${path}`;

const service = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name,
  description,
  provider: {
    '@type': 'Painter',
    name: business.name,
    telephone: business.phone.schema,
    url: business.url,
    sameAs: [business.sameAs[0]],
    address: {
      '@type': 'PostalAddress',
      addressLocality: business.address.addressLocality,
      postalCode: business.address.postalCode,
      addressCountry: business.address.addressCountry,
    },
    aggregateRating: { '@type': 'AggregateRating', ...business.aggregateRating },
  },
  areaServed: { '@type': 'City', name: 'Hamburg' },
  ...(offers && offers.length
    ? {
        offers: offers.map((o) => ({
          '@type': 'Offer',
          name: o.name,
          priceCurrency: 'EUR',
          price: o.price,
        })),
      }
    : {}),
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: business.url },
    { '@type': 'ListItem', position: 2, name: breadcrumbName, item: pageUrl },
  ],
};
---
<script type="application/ld+json" set:html={JSON.stringify(service)} is:inline />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} is:inline />
