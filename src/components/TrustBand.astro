---
// Vertrauens-Band — zwei Versprechen, die der Hero nicht schon zeigt.
---
<section class="trust" aria-label="Qualifikationen auf einen Blick">
  <div class="container">
    <div class="trust-grid">
      <div class="trust-item">
        <p class="trust-label">Besichtigung</p>
        <h3>Kostenloser Vor-Ort-Termin</h3>
        <p>Kein Risiko, kein Auftragsdruck — wir schauen erst an, dann entscheiden Sie.</p>
      </div>
      <div class="trust-item">
        <p class="trust-label">Preisgarantie</p>
        <h3>Schriftlicher Festpreis</h3>
        <p>Kein Stundensatz. Der vereinbarte Preis gilt — ohne Nachkalkulation.</p>
      </div>
    </div>
  </div>
</section>
