---
// Ablauf-Sektion (3 Schritte) für Service-Seiten.
interface Step {
  h: string;
  p: string;
}
interface Props {
  steps: Step[];
  title: string;
  kicker?: string;
}
const { steps, title, kicker = 'Ablauf' } = Astro.props;
---
<section>
  <div class="container">
    <p class="section-kicker">{kicker}</p>
    <h2>{title}</h2>
    <ol class="ablauf">
      {steps.map((s, i) => (
        <li class="ablauf-step">
          <span class="step-num" aria-hidden="true">{i + 1}</span>
          <h3>{s.h}</h3>
          <p>{s.p}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
